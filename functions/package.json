{
  "name": "functions",
  "scripts": {
    "lint": "eslint --config eslint.config.js .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "admin:provision": "npm run build && node lib/scripts/provisionAdmin.js",
    "seed": "npm run seed:stations",
    "seed:stations": "npm run build && node lib/scripts/seedStationDirectory.js",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,storage,auth,hosting",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "nodemailer": "^8.0.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "typescript": "^5.7.3"
  },
  "private": true
}
