rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid));
    }

    function isRole(role) {
      return signedIn() && currentUserDoc().data.role == role;
    }

    function isAdmin() {
      return isRole("admin");
    }

    function isStation() {
      return isRole("station");
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /accounts/{uid} {
      allow read: if isOwner(uid) || isAdmin() || (signedIn() && resource.data.role in ["resident", "station"]);
      allow create: if isOwner(uid)
        && request.resource.data.role == "station"
        && request.resource.data.email is string
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.brand is string
        && request.resource.data.barangay is string
        // Prevent clients from setting server-managed fields.
        && !("fuelInventory" in request.resource.data)
        && !("fuelPrices" in request.resource.data)
        && !("assignedAt" in request.resource.data)
        && !("inviteAcceptedAt" in request.resource.data)
        && !("lastSeenAt" in request.resource.data)
        // Allow registrationToken to be set during station registration
        && (request.resource.data.registrationToken == null || (
          request.resource.data.registrationToken.token is string
          && request.resource.data.registrationToken.used is bool
        ));
      allow update: if (isOwner(uid) && isStation()
        // Prevent direct manipulation of fuel config layout; fuelInventory + fuelPrices are allowed.
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["availableFuels", "fuelCapacities"]))
        || (isOwner(uid) && isRole("resident") && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vehicles', 'plateNormalizedList']))
        // Allow station officers to update resident fuel tracking fields during dispense.
        || (isStation() && resource.data.role == "resident"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["vehicles", "fuelUsed", "fuelWeekKey", "updatedAt"]));
      allow delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.residentUid == request.auth.uid)
        || (signedIn() && resource.data.stationUid == request.auth.uid);
      allow create: if isStation() && request.resource.data.stationUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /stationDirectory/{stationId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == stationId
        && request.resource.data.accountUid == stationId
        && request.resource.data.name is string
        && request.resource.data.brand is string
        && request.resource.data.address is string
        && request.resource.data.hours is string
        && request.resource.data.lat is number
        && request.resource.data.lon is number
        && request.resource.data.fuels is list;
      allow update: if signedIn()
        && request.auth.uid == stationId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fuels", "updatedAt"]);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
