rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid));
    }

    function isRole(role) {
      return signedIn() && currentUserDoc().data.role == role;
    }

    function isAdmin() {
      return isRole("admin");
    }

    function isStation() {
      return isRole("station");
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function stationCanUpdateResidentFuelUsage() {
      return isStation()
        && resource.data.role == "resident"
        && request.resource.data.role == resource.data.role
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fuelUsed", "fuelWeekKey", "updatedAt"])
        && request.resource.data.fuelUsed is number
        && request.resource.data.fuelUsed >= 0
        && (
          !request.resource.data.keys().hasAny(["fuelWeekKey"])
          || request.resource.data.fuelWeekKey is string
        )
        && (
          request.resource.data.fuelWeekKey != resource.data.fuelWeekKey
          || !(resource.data.fuelUsed is number)
          || request.resource.data.fuelUsed >= resource.data.fuelUsed
        );
    }

    match /accounts/{uid} {
      allow read: if isOwner(uid) || isAdmin() || (isStation() && resource.data.role in ["resident", "station"]);
      allow update: if (isOwner(uid) && isStation()) || stationCanUpdateResidentFuelUsage();
      allow create, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.residentUid == request.auth.uid)
        || (signedIn() && resource.data.stationUid == request.auth.uid);
      allow create: if isStation() && request.resource.data.stationUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /stationDirectory/{stationId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /stationInvites/{inviteId} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
