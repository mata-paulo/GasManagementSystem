# Firebase (Vite) — copy to `.env` and fill from Firebase Console → Project settings → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
# Optional: Functions region (default asia-southeast1)
# VITE_FIREBASE_FUNCTIONS_REGION=asia-southeast1
# Optional: use local emulators
# VITE_USE_FIREBASE_EMULATORS=true
